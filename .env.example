# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI — use one of the following:
# Vercel AI Gateway (recommended for production on Vercel)
AI_GATEWAY_API_KEY=your-ai-gateway-key
# Or OpenAI directly for local development
OPENAI_API_KEY=sk-your-openai-key
# Optional: image model for Xiaohei visualizations (requires AI Gateway)
# XIAOHEI_IMAGE_MODEL=google/gemini-2.5-flash-image

# Email (optional — welcome & study-set-ready notifications)
# Sandbox: only RESEND_API_KEY is required. Emails send from onboarding@resend.dev
# and can only be delivered to the email address on your Resend account.
RESEND_API_KEY=re_your-resend-key
# RESEND_FROM_EMAIL=StudyBuddy <onboarding@resend.dev>  # optional; this is the default
# Production: verify your own domain in Resend, then set RESEND_FROM_EMAIL=StudyBuddy <hello@yourdomain.com>

# Eve agent — mounted via withEve() in next.config.ts
# Optional override for server-side Eve client calls:
# EVE_AGENT_URL=http://127.0.0.1:3000

# Sentry — error monitoring and performance tracing
# Required: copy DSN from Sentry → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Optional: OTLP traces endpoint from the same Client Keys page (OpenTelemetry tab).
# Not required — @sentry/nextjs sends errors and traces via the DSN above.
# SENTRY_OTLP_TRACES_ENDPOINT=

# Optional: only for production source map uploads at build time (not needed locally)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
